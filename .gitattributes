# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source files
*.py     text eol=lf
*.pyi    text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.rst    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.sh     text eol=lf
*.bat    text eol=crlf

# Templates / Jupyter
*.j2     text eol=lf
*.jinja2 text eol=lf
*.ipynb  text eol=lf

# Licenses
LICENSE  text eol=lf
COPYING  text eol=lf
NOTICE   text eol=lf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.tgz   binary
*.bz2   binary
*.7z    binary
*.db    binary
*.sqlite binary
*.sqlite3 binary

# Fonts — treat as binary, never diff
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.eot   binary

# Documents
*.doc   binary
*.docx  binary
*.xls   binary
*.xlsx  binary
*.ppt   binary
*.pptx  binary

# Linguist detection — vendored / generated files
docs/_build/** linguist-generated=true
src/multimind/_version.py linguist-generated=true

# Export-ignore in GitHub archives
.github/export-ignore/** export-ignore
